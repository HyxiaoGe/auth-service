# 复制为 .env 后再填写。不要提交 .env、私钥或任何真实凭据。

# ========== Application ==========
APP_NAME=auth-service
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8100
APP_DEBUG=true
AUTH_BASE_URL=http://localhost:8100
# 仅用于 development 本地联调：逗号分隔的精确 loopback auth-service origin。
# 生产环境必须留空；这里不是 RP/CORS 白名单。
AUTH_BROWSER_ALIASES=
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,app://-

# ========== Docker Compose self-hosting ==========
# 默认拉取固定版本的公开镜像。克隆源码后如需本地构建，请叠加 docker-compose.build.yml。
COMPOSE_FILE=compose.yaml
AUTH_SERVICE_IMAGE=ghcr.io/hyxiaoge/auth-service:v1.1.0
AUTH_BOOTSTRAP_TIMEOUT_SECONDS=120

# 默认启用 Compose 内置 PostgreSQL 与 Redis；使用外部服务时留空。
COMPOSE_PROFILES=bundled

# 使用 `openssl rand -hex 32` 生成并替换此占位符。
POSTGRES_USER=auth_service
POSTGRES_PASSWORD=replace-with-a-64-character-random-hex-value
POSTGRES_DB=auth_service

# 内置模式保持留空，由 Compose 从 POSTGRES_* 自动生成容器内地址。
# 外部模式必须填写三项完整 URL；密码中的 @、:、/ 等保留字符必须 URL 编码。
DATABASE_URL=
DATABASE_URL_SYNC=
REDIS_URL=

# ========== JWT ==========
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ALGORITHM=RS256
JWT_TRUSTED_JWKS_PATH=
JWT_TRUSTED_ISSUER=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_REUSE_GRACE_SECONDS=5
AUTH_CODE_EXPIRE_SECONDS=300

# ========== SSO session ==========
SESSION_COOKIE_SAMESITE=lax
# SESSION_COOKIE_DOMAIN=.example.com
SESSION_TTL_SECONDS=604800
SESSION_ABSOLUTE_MAX_SECONDS=2592000
# 必须不少于 REFRESH_TOKEN_EXPIRE_DAYS 对应秒数再加 60 秒。
SID_REVOCATION_TTL_SECONDS=2592060

# ========== Google OAuth (optional) ==========
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ========== GitHub OAuth (optional) ==========
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ========== Passwordless email login (optional, disabled by default) ==========
EMAIL_LOGIN_ENABLED=false
EMAIL_HEADLESS_LOGIN_ENABLED=false
EMAIL_CODE_PEPPER=
EMAIL_CODE_TTL_SECONDS=300
EMAIL_FLOW_TTL_SECONDS=600
EMAIL_FLOW_RECOVERY_TTL_SECONDS=3600
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODE_MAX_ATTEMPTS=5
EMAIL_RATE_LIMIT_PER_EMAIL=5
EMAIL_RATE_LIMIT_PER_IP=20
EMAIL_RATE_LIMIT_PER_FLOW=3
EMAIL_SEND_RATE_LIMIT_GLOBAL=1000
EMAIL_AUTHORIZE_RATE_LIMIT_PER_IP=60
EMAIL_AUTHORIZE_RATE_LIMIT_PER_CLIENT=2000
EMAIL_AUTHORIZE_RATE_LIMIT_GLOBAL=10000
EMAIL_SEND_REQUEST_RATE_LIMIT_PER_IP=120
EMAIL_SEND_REQUEST_RATE_LIMIT_PER_FLOW=15
EMAIL_SEND_REQUEST_RATE_LIMIT_GLOBAL=10000
EMAIL_VERIFY_RATE_LIMIT_PER_IP=120
EMAIL_VERIFY_RATE_LIMIT_PER_FLOW=15
EMAIL_VERIFY_RATE_LIMIT_GLOBAL=10000
EMAIL_RATE_LIMIT_WINDOW_SECONDS=3600
EMAIL_FLOW_MAX_PER_BROWSER=5

# SMTP 默认使用 STARTTLS (587)。隐式 TLS (465) 应设置 SMTP_USE_SSL=true、SMTP_STARTTLS=false。
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Auth Service
SMTP_SMOKE_RECIPIENT=
SMTP_STARTTLS=true
SMTP_USE_SSL=false
SMTP_ALLOW_PLAINTEXT_DEVELOPMENT=false
SMTP_TIMEOUT_SECONDS=10

# 配置 API Key 后使用 Resend；留空则使用 SMTP。
RESEND_API_KEY=
RESEND_MONTHLY_QUOTA=3000
RESEND_DAILY_QUOTA=100
RESEND_TIMEOUT_SECONDS=10
RESEND_PREFLIGHT_CACHE_PATH=
RESEND_PREFLIGHT_CACHE_TTL_SECONDS=3600

# 公网 HTTPS + 邮箱登录时必须填写精确的直连代理 CIDR，不能填写宽泛网段。
TRUSTED_PROXY_CIDRS=

# ========== Legacy internal password compatibility (disabled by default) ==========
# 这不是面向终端用户的账密登录能力。若无受控的旧系统兼容需求，请保持关闭和留空。
PASSWORD_AUTH_ENABLED=false
PASSWORD_AUTH_INTERNAL_TOKEN=
PASSWORD_AUTH_EMAIL_PREFIX=
PASSWORD_AUTH_EMAIL_DOMAIN=
