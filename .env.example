# ========== App ==========
APP_NAME=auth-service
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8100
APP_DEBUG=true

# ========== Database ==========
DATABASE_URL=postgresql+asyncpg://sean:sean_auth_pass@postgres:5432/auth
DATABASE_URL_SYNC=postgresql://sean:sean_auth_pass@postgres:5432/auth

# ========== Redis ==========
# SSO 会话、授权码与邮箱验证码状态共用 Redis；dev 使用 middleware Compose 的服务 DNS。
REDIS_URL=redis://middleware-redis:6379/0

# ========== 邮箱验证码登录 ==========
# 默认关闭；SMTP 与至少 32 字符的随机 pepper 配置完成后再启用。
EMAIL_LOGIN_ENABLED=false
# Headless JSON 登录独立灰度；启用前确保 Fusion Origin 同时位于 CORS_ORIGINS 与应用回调 Origin。
EMAIL_HEADLESS_LOGIN_ENABLED=false
EMAIL_CODE_PEPPER=
EMAIL_CODE_TTL_SECONDS=300
EMAIL_FLOW_TTL_SECONDS=600
EMAIL_FLOW_RECOVERY_TTL_SECONDS=3600
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODE_MAX_ATTEMPTS=5
EMAIL_RATE_LIMIT_PER_EMAIL=5
EMAIL_RATE_LIMIT_PER_IP=20
EMAIL_RATE_LIMIT_PER_FLOW=3
EMAIL_SEND_RATE_LIMIT_GLOBAL=1000
EMAIL_AUTHORIZE_RATE_LIMIT_PER_IP=60
EMAIL_AUTHORIZE_RATE_LIMIT_PER_CLIENT=2000
EMAIL_AUTHORIZE_RATE_LIMIT_GLOBAL=10000
EMAIL_RATE_LIMIT_WINDOW_SECONDS=3600
EMAIL_FLOW_MAX_PER_BROWSER=5

# 默认使用 STARTTLS（587）；隐式 TLS（465）需将 SMTP_USE_SSL=true、SMTP_STARTTLS=false。
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Sean Auth
# 部署、进程启动和故障恢复会向此专用地址提交明确标记的预检邮件；只验证 SMTP 接受，不证明收件箱送达或 SPF/DKIM。
SMTP_SMOKE_RECIPIENT=
SMTP_STARTTLS=true
SMTP_USE_SSL=false
# 即使此项为 true，生产环境和公开 HTTPS 环境仍拒绝明文 SMTP。
SMTP_ALLOW_PLAINTEXT_DEVELOPMENT=false
SMTP_TIMEOUT_SECONDS=10

# 可提供 X-Forwarded-For 的直连可信对端 CIDR，以逗号分隔；服务不读取 CF-Connecting-IP。
# dev 当前直连 nginx-proxy 为 172.25.0.10；启用前至少精确信任 172.25.0.10/32。
# 不要信任整个 172.25.0.0/16 容器网段；部署时必须根据 docker inspect 与访问日志重新确认。
TRUSTED_PROXY_CIDRS=

# ========== JWT ==========
# RSA key paths (generate with: python scripts/generate_keys.py)
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ========== OAuth: Google ==========
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ========== OAuth: GitHub ==========
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ========== Auth Service ==========
# The public-facing URL of this auth service
AUTH_BASE_URL=http://localhost:8100

# ========== CORS ==========
# Comma-separated allowed origins. Headless clients must additionally be schemeful
# same-site with AUTH_BASE_URL; CORS alone does not enable in-app email login.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,app://-
